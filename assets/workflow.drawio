<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="ttsCN Workflow">
    <mxGraphModel dx="900" dy="900" grid="1" gridSize="10" pageWidth="600" pageHeight="900">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Actor labels (left column) -->
        <mxCell id="actor-user" value="USER" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#6c8ebf;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="20" y="55" width="50" height="20" as="geometry" />
        </mxCell>
        <mxCell id="actor-claude" value="CLAUDE" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#82b366;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="20" y="335" width="50" height="20" as="geometry" />
        </mxCell>
        <mxCell id="actor-api" value="TTS API" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#d79b00;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="20" y="575" width="50" height="20" as="geometry" />
        </mxCell>
        <mxCell id="actor-output" value="OUTPUT" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#666666;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="20" y="695" width="50" height="20" as="geometry" />
        </mxCell>

        <!-- 1. User provides text -->
        <mxCell id="2" value="Provide text to speak&#xa;(inline string or .txt file)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 2. Claude understands requirements -->
        <mxCell id="3" value="Understand requirements&#xa;(voice style · speed · format · length)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 3. Recommend backend + voice -->
        <mxCell id="4" value="Recommend backend &amp; voice&#xa;(match use case → best platform)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="215" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 4. Decision: Right choice? -->
        <mxCell id="5" value="Right choice?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="300" width="280" height="70" as="geometry" />
        </mxCell>

        <!-- 5. User confirms -->
        <mxCell id="6" value="User confirms&#xa;('ok' / 'go' / 'synthesize')" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="410" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 6. Load config + select backend/voice -->
        <mxCell id="7" value="Load config (~/.ttsCN.json)&#xa;Select backend, voice &amp; rate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 7. Synthesize via TTS API -->
        <mxCell id="8" value="Synthesize via TTS API&#xa;(8 backends / 800+ voices)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="585" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 8. Post-process + save -->
        <mxCell id="9" value="Post-process (ffmpeg)&#xa;Save as .wav or .mp3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="670" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 9. Success -->
        <mxCell id="10" value="&#x2713; Audio generated &amp; saved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="755" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- EDGES -->

        <!-- 1→2: User provides text → Claude understand -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;" edge="1" parent="1" source="2" target="3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 2→3: Claude understand → Recommend -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;endArrow=block;endFill=1;" edge="1" parent="1" source="3" target="4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 3→4: Recommend → Decision -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4→5 (Yes): Decision → User confirms -->
        <mxCell id="e4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;endArrow=block;endFill=1;fontColor=#82b366;fontStyle=1;fontSize=11;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4→2 (No loop-back): Decision → Claude understand -->
        <mxCell id="e5" value="No — try again" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;endArrow=block;endFill=1;fontColor=#d6b656;fontStyle=1;fontSize=11;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="5" target="3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="10" y="335" />
              <mxPoint x="10" y="155" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 5→6: User confirms → Config -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;" edge="1" parent="1" source="6" target="7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 6→7: Config → API call -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;endArrow=block;endFill=1;" edge="1" parent="1" source="7" target="8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 7→8: API → Save -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;endArrow=block;endFill=1;" edge="1" parent="1" source="8" target="9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 8→9: Save → Success -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;endArrow=block;endFill=1;" edge="1" parent="1" source="9" target="10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Annotation: 8 backends -->
        <mxCell id="note1" value="Edge TTS · Doubao · CosyVoice&#xa;Azure · Tencent · Baidu&#xa;MiniMax · Xunfei" style="text;html=1;fontSize=9;fontColor=#999999;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="320" y="585" width="140" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
